SELECT
    su.fullname AS DisplayName,
    su.domainname AS UserPrincipalName,
    su.internalemailaddress AS Email,
    su.title AS JobTitle,
   
    su.isdisabled AS IsDisabled,
    su.islicensed AS IsLicensed,
    su.accessmode AS AccessMode,
    MAX(a.createdon) AS LastLoginDate
FROM
    systemuser su
LEFT JOIN
    audit a
    ON a.objectid = su.systemuserid
    AND a.operation = 4
    AND a.createdon >= '2025-11-01'
WHERE
    su.islicensed = 1
    AND su.isdisabled = 0
GROUP BY
    su.fullname,
    su.domainname,
    su.internalemailaddress,
    su.title,
    su.isdisabled,
    su.islicensed,
    su.accessmode
ORDER BY
    MAX(a.createdon) DESC
