# ============================================================
# Export ALL enabled Dynamics 365 / Dataverse users
# with their environment license status
# ============================================================

[System.Net.ServicePointManager]::SecurityProtocol = [System.Net.SecurityProtocolType]::Tls12

Install-Module Microsoft.Xrm.Tooling.CrmConnector.PowerShell -Scope CurrentUser -Force
Install-Module Microsoft.Xrm.Data.PowerShell -Scope CurrentUser -Force

Import-Module Microsoft.Xrm.Tooling.CrmConnector.PowerShell
Import-Module Microsoft.Xrm.Data.PowerShell

# =========================
# CONFIGURATION
# =========================

$EnvironmentUrl = "https://YOURORG.crm.dynamics.com"
$ExportPath = "C:\Temp\D365_All_Enabled_Users_With_License_Status.csv"

$ExportFolder = Split-Path $ExportPath
if (!(Test-Path $ExportFolder)) {
    New-Item -ItemType Directory -Path $ExportFolder -Force | Out-Null
}

# =========================
# CONNECT
# =========================

Write-Host "Connecting to Dataverse..." -ForegroundColor Cyan

$CRMConn = Get-CrmConnection -InteractiveMode -ServerUrl $EnvironmentUrl

if ($null -eq $CRMConn -or $CRMConn.IsReady -ne $true) {
    Write-Host "Connection failed." -ForegroundColor Red
    return
}

Write-Host "Connected successfully." -ForegroundColor Green

# =========================
# FETCH ALL ENABLED USERS
# =========================

$FetchXml = @"
<fetch version='1.0' mapping='logical' distinct='false'>
  <entity name='systemuser'>
    <attribute name='systemuserid' />
    <attribute name='fullname' />
    <attribute name='domainname' />
    <attribute name='internalemailaddress' />
    <attribute name='title' />
    <attribute name='department' />
    <attribute name='isdisabled' />
    <attribute name='islicensed' />
    <attribute name='accessmode' />
    <attribute name='businessunitid' />
    <order attribute='fullname' descending='false' />
    <filter type='and'>
      <condition attribute='isdisabled' operator='eq' value='0' />
    </filter>
  </entity>
</fetch>
"@

Write-Host "Retrieving all enabled users..." -ForegroundColor Cyan

$QueryResult = Get-CrmRecordsByFetch -conn $CRMConn -Fetch $FetchXml -AllRows
$Users = $QueryResult.CrmRecords

if ($null -eq $Users -or $Users.Count -eq 0) {
    Write-Host "No enabled users found in this environment." -ForegroundColor Yellow
    return
}

$Results = foreach ($User in $Users) {

    $LicensedValue = $User.islicensed

    [PSCustomObject]@{
        SystemUserId      = $User.systemuserid
        DisplayName       = $User.fullname
        UserPrincipalName = $User.domainname
        Email             = $User.internalemailaddress
        JobTitle          = $User.title
        Department        = $User.department
        BusinessUnit      = $User.businessunitid
        IsDisabled        = $User.isdisabled
        IsLicensed        = $User.islicensed
        AccessMode        = $User.accessmode
        LicenseStatus     = if ($User.islicensed -eq $true -or $User.islicensed -eq "True") {
            "Licensed"
        }
        else {
            "Not Licensed"
        }
    }
}

$Results |
    Sort-Object DisplayName |
    Export-Csv $ExportPath -NoTypeInformation -Encoding UTF8

$Results |
    Group-Object LicenseStatus |
    Select-Object Name, Count |
    Format-Table -AutoSize

$Results |
    Sort-Object DisplayName |
    Format-Table DisplayName, UserPrincipalName, Email, IsDisabled, IsLicensed, AccessMode, LicenseStatus -AutoSize

Write-Host ""
Write-Host "Export completed successfully." -ForegroundColor Green
Write-Host "Total enabled users found: $($Results.Count)" -ForegroundColor Green
Write-Host "File exported to: $ExportPath" -ForegroundColor Green
