SELECT
    fullname AS DisplayName,
    domainname AS UserPrincipalName,
    internalemailaddress AS Email,
    isdisabled AS IsDisabled,
    islicensed AS IsLicensed,
    accessmode AS AccessMode
FROM
    systemuser
WHERE
    isdisabled = 0
    AND islicensed = 0
    AND accessmode = 0
ORDER BY
    fullname
